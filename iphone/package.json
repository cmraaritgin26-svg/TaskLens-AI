{
  "name": "health-task-tracker-iphone",
  "version": "1.0.0",
  "description": "iPhone copy of Health and Task Tracker that can run from local files or be bundled into a signed iOS app.",
  "private": false,
  "type": "module",
  "scripts": {
    "pack:iphone": "npm pack --pack-destination ..",
    "native:sync": "npx cap sync ios",
    "native:add:ios": "npx cap add ios",
    "native:open:ios": "npx cap open ios",
    "serve": "python -m http.server 8080"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  },
  "files": [
    "index.html",
    "app.js",
    "styles.css",
    "fonts",
    "manifest.webmanifest",
    "service-worker.js",
    "capacitor.config.json",
    "NATIVE_INSTALL.md",
    "README.md",
    "icons/icon.svg",
    "icons/icon-192.png",
    "icons/icon-512.png"
  ]
}
