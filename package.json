{
  "name": "habit-health-tracker-android",
  "version": "1.0.0",
  "description": "Installable Android PWA for tracking habits, health metrics, nutrition, and weight.",
  "private": false,
  "type": "module",
  "scripts": {
    "pack:android": "npm pack",
    "native:sync": "npx cap sync android",
    "native:add:android": "npx cap add android",
    "native:open:android": "npx cap open android",
    "serve": "python -m http.server 8080"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0"
  },
  "files": [
    "index.html",
    "app.js",
    "styles.css",
    "manifest.webmanifest",
    "service-worker.js",
    "www",
    "capacitor.config.json",
    "NATIVE_INSTALL.md",
    "README.md",
    "DEPLOY.md",
    "icons/icon.svg",
    "icons/icon-192.png",
    "icons/icon-512.png"
  ]
}
